# ─────────────────────────────────────────────────────────────
# ict_x_claude — environment template
# Copy to .env and fill in real values. .env is git-ignored.
# ─────────────────────────────────────────────────────────────

# Telegram (notifier + commander for /status /pause /resume /flatten /stop /restart)
# Create your bot via @BotFather, then get your chat_id from @userinfobot.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Data sources (recommended: copies under the project's data/ folder)
ICT_L2_CSV_DIR=C:/ict_x_claude/data/Data_Historica_L2_V2
ICT_BACKTEST_API_URL=http://localhost:8080/backtest/

# Symbol scope — September 2026 contracts (June expired 2026-06-20)
ICT_SYMBOL=ENQU26
ICT_CONTINUOUS_SYMBOL=MNQ
ICT_TIMEZONE=America/New_York
ICT_LOG_LEVEL=INFO

# Broker (Quantower → Lucid bridge); detailed knobs in configs/lucid_propfirm.yaml
BROKER_NAME=lucid_quantower
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=
BROKER_PAPER_MODE=false
