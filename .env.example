# Data sources
ICT_L2_CSV_DIR=C:/claude_algo_4/analisis_ml_v1/Data_Historica_L2_V2
ICT_BACKTEST_API_URL=http://localhost:8080/backtest/

# Symbol scope (V1: NQ only)
